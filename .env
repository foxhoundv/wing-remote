# ─────────────────────────────────────────────────────────────────────────────
# WING Remote — .env  (copy to .env and edit)
# ─────────────────────────────────────────────────────────────────────────────

# ── Behringer Wing ────────────────────────────────────────────────────────────
# IP address of your Wing on the network
WING_IP=192.168.1.100

# Wing OSC port — this is FIXED at 2223 on all Wing firmware. Do not change.
WING_OSC_PORT=2223

# UDP port THIS server listens on for Wing push events (subscription replies)
# Wing will send subscription events back to the IP/port that sent /*S
# Must NOT be 2223 (that's Wing's port). Recommend 2224.
LOCAL_OSC_PORT=2224


# ── Audio / Recording ─────────────────────────────────────────────────────────
# Sample rate — Wing supports 48000 and 44100 (and 96000 on some builds)
SAMPLE_RATE=48000

# Bit depth — 16, 24, or 32 (32 = 32-bit float, highest quality, no clipping)
BIT_DEPTH=32

# Number of input channels to record (Wing USB audio: up to 32 channels)
RECORD_CHANNELS=32

# Host directory where recorded WAV files are saved
RECORDINGS_DIR=/recordings


# ── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# UDP port Wing sends hardware meter data to (binary protocol)
METER_UDP_PORT=2225
